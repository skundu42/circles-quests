# Circles RPC
CIRCLES_RPC_URL=https://rpc.aboutcircles.com/
CIRCLES_CHAIN_RPC_URL=https://rpc.aboutcircles.com/
NEXT_PUBLIC_CIRCLES_RPC_URL=https://rpc.aboutcircles.com/

# Wallet auth secret (server-side)
QUEST_AUTH_SECRET=replace-with-strong-secret

# Supabase (required)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_QUEST_COMPLETIONS_TABLE=quest_completions
SUPABASE_QUEST_AUTH_CHALLENGES_TABLE=quest_auth_challenges

# Tx confirmation requirement for tx-backed quest claims
QUEST_MIN_CONFIRMATIONS=1

# Quest thresholds/defaults
QUEST_SEND_MIN_CRC=5
QUEST_SEND_EXECUTION_CRC=5.1
QUEST_GCRC_MINT_AMOUNT_CRC=5

# Max allowed image payload size (characters) for group image input
QUEST_GROUP_IMAGE_MAX_INPUT_CHARS=700000
